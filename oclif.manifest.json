    "init": {
      "aliases": [],
      "args": {},
      "description": "Create reopenspec/docs/, reopenspec/specs/.meta, reopenspec/changes/active/ and reopenspec/changes/completed/, scan TypeScript, write arch-baseline.json, reopenspec.json, inject IDE workflows, copy Cursor slash-command templates to .cursor/commands/, copy categorized rules (generic always + specific per stack), optionally configure MCP in ~/.cursor/mcp.json, and add reopenspec.project.yaml if missing (use --skip-workflow / --skip-mcp-setup / --skip-rules to opt out).",
      "examples": [
        "<%= config.bin %> init",
        "<%= config.bin %> init -c . --force",
        "<%= config.bin %> init --skip-workflow",
        "<%= config.bin %> init --skip-mcp-setup",
        "<%= config.bin %> init --backend dotnet --frontend vue",
        "<%= config.bin %> init --backend node --no-auto-detect",
        "<%= config.bin %> init --skip-rules"
      ],
      "flags": {
        "cwd": {
          "char": "c",
          "description": "Workspace root",
          "name": "cwd",
          "default": ".",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "force": {
          "description": "Overwrite existing reopenspec.json",
          "name": "force",
          "allowNo": false,
          "type": "boolean"
        },
        "skipInject": {
          "description": "Do not write Cursor / .ai-context workflow files",
          "name": "skipInject",
          "allowNo": false,
          "type": "boolean"
        },
        "skipWorkflow": {
          "description": "Do not copy slash-command templates to .cursor/commands/ or add reopenspec.project.yaml",
          "name": "skipWorkflow",
          "allowNo": false,
          "type": "boolean"
        },
        "skipMcpSetup": {
          "description": "Do not prompt to merge MCP server entries into ~/.cursor/mcp.json (Cursor user config)",
          "name": "skipMcpSetup",
          "allowNo": false,
          "type": "boolean"
        },
        "skipRules": {
          "description": "Do not copy any rule files to the IDE rules directory",
          "name": "skipRules",
          "allowNo": false,
          "type": "boolean"
        },
        "backend": {
          "description": "Backend stack for specific rules (e.g. dotnet, node, php, python). Overrides auto-detection.",
          "name": "backend",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "dotnet",
            "node",
            "php",
            "python"
          ],
          "type": "option"
        },
        "frontend": {
          "description": "Frontend stack for specific rules (e.g. vue, react, flutter). Overrides auto-detection.",
          "name": "frontend",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "vue",
            "react",
            "flutter"
          ],
          "type": "option"
        },
        "database": {
          "description": "Include database/SQL rules",
          "name": "database",
          "allowNo": false,
          "type": "boolean"
        },
        "devops": {
          "description": "Include CI/CD and deployment rules",
          "name": "devops",
          "allowNo": false,
          "type": "boolean"
        },
        "figma": {
          "description": "Include Figma design-to-code rules (requires --frontend)",
          "name": "figma",
          "allowNo": false,
          "type": "boolean"
        },
        "autoDetect": {
          "description": "Auto-detect stacks from manifests and copy matching rules (default: true)",
          "name": "autoDetect",
          "allowNo": true,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "init",
      "pluginAlias": "reopenspec",
