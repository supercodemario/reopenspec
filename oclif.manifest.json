    "init": {
      "aliases": [],
      "args": {},
      "description": "Create reopenspec/docs/, reopenspec/specs/.meta, reopenspec/changes/active/ and reopenspec/changes/completed/, scan TypeScript, write arch-baseline.json, reopenspec.json, inject IDE workflows, copy Cursor slash-command templates to .cursor/commands/, optionally configure MCP in ~/.cursor/mcp.json, and add reopenspec.project.yaml if missing (use --skip-workflow / --skip-mcp-setup to opt out).",
      "examples": [
        "<%= config.bin %> init",
        "<%= config.bin %> init -c . --force",
        "<%= config.bin %> init --skip-workflow",
        "<%= config.bin %> init --skip-mcp-setup"
      ],
      "flags": {
        "cwd": {
          "char": "c",
          "description": "Workspace root",
          "name": "cwd",
          "default": ".",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "force": {
          "description": "Overwrite existing reopenspec.json",
          "name": "force",
          "allowNo": false,
          "type": "boolean"
        },
        "skipInject": {
          "description": "Do not write Cursor / .ai-context workflow files",
          "name": "skipInject",
          "allowNo": false,
          "type": "boolean"
        },
        "skipWorkflow": {
          "description": "Do not copy slash-command templates to .cursor/commands/ or add reopenspec.project.yaml",
          "name": "skipWorkflow",
          "allowNo": false,
          "type": "boolean"
        },
        "skipMcpSetup": {
          "description": "Do not prompt to merge MCP server entries into ~/.cursor/mcp.json (Cursor user config)",
          "name": "skipMcpSetup",
          "allowNo": false,
          "type": "boolean"
        },
        "heroName": {
          "description": "Hero name (gitignored); skips interactive name/role prompts when set",
          "name": "heroName",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "role": {
          "description": "Local role: developer or manager; skips interactive role prompt when set",
          "name": "role",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "developer",
            "manager"
          ],
          "type": "option"
        },
        "emoji": {
          "description": "Hero emoji override (defaults: developer 🥷, manager 🔀)",
          "name": "emoji",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        }
