    "config": {
      "aliases": [],
      "args": {
        "action": {
          "description": "print (default) | path | init",
          "name": "action",
          "required": false
        }
      },
      "description": "Inspect or create reopenspec.json. Hero name, role, and emoji live in gitignored reopenspec.local.json.",
      "examples": [
        "<%= config.bin %> config",
        "<%= config.bin %> config path",
        "<%= config.bin %> config init"
      ],
      "flags": {
        "cwd": {
          "char": "c",
          "description": "Workspace root",
          "name": "cwd",
          "default": ".",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "force": {
          "description": "Overwrite existing reopenspec.json (init only)",
          "name": "force",
          "allowNo": false,
          "type": "boolean"
        },
        "heroName": {
          "description": "Hero name → reopenspec.local.json (init only)",
          "name": "heroName",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "role": {
          "description": "developer | manager (init only, with --hero-name)",
          "name": "role",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "developer",
            "manager"
          ],
          "type": "option"
        },
        "emoji": {
          "description": "Emoji override (init only, with --hero-name)",
          "name": "emoji",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
